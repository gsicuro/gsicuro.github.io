@article{SICURO20172583,
 abstract = {We introduce a generalized representation of the Dirac delta function in d dimensions in terms of q-exponential functions. We apply this new representation to the study of the so-called q-Fourier transform and we establish the analytical procedure through which it can be inverted for any value of d. We finally illustrate the effect of the q-deformation on the Gibbs phenomenon of Fourier series expansions.},
 author = {Gabriele Sicuro and Constantino Tsallis},
 doi = {https://doi.org/10.1016/j.physleta.2017.06.006},
 issn = {0375-9601},
 journal = {Physics Letters A},
 keywords = {Tsallis entropy, -exponential, -Dirac delta, -Fourier transform},
 number = {32},
 pages = {2583-2587},
 title = {q-generalized representation of the d-dimensional Dirac delta and q-Fourier transform},
 url = {https://www.sciencedirect.com/science/article/pii/S0375960117305625},
 volume = {381},
 year = {2017}
}

